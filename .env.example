# =============================================================================
# alexandria-vector-shelf-mcp — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env or service-account.json to version control.
#
# Where to find each value:
#   Firebase console:   https://console.firebase.google.com → Project Settings
#   Google Cloud:       https://console.cloud.google.com
#   OpenAI:             https://platform.openai.com/api-keys
#   Gemini:             https://aistudio.google.com/apikey
# =============================================================================


# -----------------------------------------------------------------------------
# Google Cloud / Firebase
# -----------------------------------------------------------------------------

# Your GCP project ID (found in Firebase console → Project Settings)
GOOGLE_CLOUD_PROJECT=

# Firebase Storage bucket name (usually <project-id>.appspot.com)
FIREBASE_STORAGE_BUCKET=

# Path to service account JSON — LOCAL DEVELOPMENT ONLY
# In production (Cloud Run), Application Default Credentials are used automatically
# NEVER commit this file to git — it is in .gitignore
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firestore database ID — use "(default)" unless you created a named database
FIRESTORE_DATABASE_ID=(default)

# Firestore collection names — change only if you need multiple environments
FIRESTORE_BOOKS_COLLECTION=books
FIRESTORE_CHUNKS_COLLECTION=chunks


# -----------------------------------------------------------------------------
# Embeddings — choose ONE provider and comment out the other
# -----------------------------------------------------------------------------

# Option A: OpenAI (simpler setup, works immediately)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Option B: Vertex AI (keeps everything in GCP, no extra cost on free tier)
# Requires GOOGLE_APPLICATION_CREDENTIALS to be set
# EMBEDDING_PROVIDER=vertex_ai
# EMBEDDING_MODEL=text-embedding-004
# EMBEDDING_DIMENSION=768
# VERTEX_AI_LOCATION=us-central1

# IMPORTANT: Never change EMBEDDING_MODEL after ingesting books.
# All stored vectors must use the same model as query-time embeddings.
# Changing models invalidates all stored embeddings.


# -----------------------------------------------------------------------------
# LLM — Gemini (Google)
# -----------------------------------------------------------------------------

# Get key at: https://aistudio.google.com/apikey
# In production on Cloud Run, use Application Default Credentials instead
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash


# -----------------------------------------------------------------------------
# Service configuration
# -----------------------------------------------------------------------------

# Local development URLs (auto-resolved in Cloud Run via service-to-service auth)
INGESTION_SERVICE_URL=http://localhost:8001
CHAT_SERVICE_URL=http://localhost:8002

# Environment — affects logging verbosity and error reporting
ENVIRONMENT=development   # development | staging | production


# -----------------------------------------------------------------------------
# Chunking parameters (Ingestion Service)
# See ADR-003 before changing these values.
# -----------------------------------------------------------------------------

# Maximum characters per chunk (~100-150 words at 500)
CHUNK_SIZE=500

# Overlap between consecutive chunks in characters
# Ensures information at chunk boundaries is not lost
CHUNK_OVERLAP=50


# -----------------------------------------------------------------------------
# Retrieval parameters (Chat Service)
# -----------------------------------------------------------------------------

# Number of chunks to retrieve per question (top-k)
# Higher = more context for the LLM (more tokens = higher cost + latency)
# Lower = faster and cheaper (may miss relevant passages)
RETRIEVAL_TOP_K=5
