# =============================================================================
# alexandria-vector-shelf-mcp — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
#
# Where to find each value:
#   Supabase: https://app.supabase.com → your project → Settings → API
#   OpenAI:   https://platform.openai.com → API Keys
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Your Supabase project URL (looks like https://xxxxxxxxxxxx.supabase.co)
# Found in: Settings → API → Project URL
SUPABASE_URL=

# Service role key — bypasses Row Level Security. SERVER-SIDE ONLY.
# NEVER expose this in the mobile app or any client-side code.
# Found in: Settings → API → Project API Keys → service_role
SUPABASE_SERVICE_KEY=

# Anon key — safe for client-side use. Respects RLS policies.
# Used by the NeoReader app (not by this backend).
# Included here for reference and local testing.
# Found in: Settings → API → Project API Keys → anon public
SUPABASE_ANON_KEY=

# Storage bucket name for epub files
# Create this bucket in: Storage → New bucket → name: "epubs" → private
SUPABASE_STORAGE_BUCKET=epubs


# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

# Your OpenAI API key
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Embedding model — do not change after first ingestion.
# Changing the model invalidates all stored embeddings.
# text-embedding-3-small: 1536 dimensions, best cost/quality ratio
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chat model — can be changed at any time without affecting stored data
OPENAI_CHAT_MODEL=gpt-4o-mini


# -----------------------------------------------------------------------------
# Service configuration
# -----------------------------------------------------------------------------

# Ingestion service — set in production, defaults to localhost in dev
INGESTION_SERVICE_URL=http://localhost:8001

# Chat service — set in production, defaults to localhost in dev
CHAT_SERVICE_URL=http://localhost:8002

# Environment — used for logging and error reporting
ENVIRONMENT=development  # development | staging | production


# -----------------------------------------------------------------------------
# Chunking parameters (Ingestion Service)
# These affect retrieval quality. See ADR-003 before changing.
# -----------------------------------------------------------------------------

# Maximum number of characters per chunk
# Default 500 ≈ 100-150 words ≈ 1-2 paragraphs
CHUNK_SIZE=500

# Overlap between consecutive chunks in characters
# Ensures that information at chunk boundaries is not lost
# Default 50 ≈ 1-2 sentences of overlap
CHUNK_OVERLAP=50


# -----------------------------------------------------------------------------
# Retrieval parameters (Chat Service)
# -----------------------------------------------------------------------------

# Number of chunks to retrieve per question (top-k)
# Higher = more context for the LLM, but more tokens = higher cost
# Lower = faster and cheaper, but may miss relevant passages
RETRIEVAL_TOP_K=5
